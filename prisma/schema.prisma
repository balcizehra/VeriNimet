// Genç İHH Raporlama Sistemi — veritabanı şeması
// Geliştirme: SQLite (dosya tabanlı, kurulum gerektirmez)
// Prodüksiyon: DATABASE_URL'i Postgres bağlantısına çevirip provider'ı "postgresql" yap.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Her il için kurumsal hesap (kişisel değil, role bağlı).
// Başkan değiştiğinde şifre sıfırlanır, hesap kalır — veri kaybolmaz.
model Il {
  id        Int    @id @default(autoincrement())
  kod       String @unique // "001", "042" gibi giriş ID'leri buraya gelecek
  ad        String @unique // "Adana", "Konya" ...
  sifreHash String
}

model Admin {
  id           Int    @id @default(autoincrement())
  kullaniciAdi String @unique
  sifreHash    String
}

// Bir il + bir birim + bir hafta = tek Rapor kaydı.
// Aynı hafta tekrar gönderilirse üzerine yazılır (upsert).
model Rapor {
  id                Int        @id @default(autoincrement())
  il                String
  birim             String // universite | lise | ortaokul | cocuk
  hafta             String // ISO hafta etiketi, örn "2026-W29"
  toplantiYapildi Boolean
  dersYapildi      Boolean
  guncellenmeTarihi DateTime @updatedAt
  olusturmaTarihi   DateTime @default(now())
  lokasyonlar       Lokasyon[]

  @@unique([il, birim, hafta])
  @@index([il, birim])
}

model Lokasyon {
  id       Int    @id @default(autoincrement())
  raporId  Int
  rapor    Rapor  @relation(fields: [raporId], references: [id], onDelete: Cascade)
  tip      String // "toplanti" | "ders"
  ad       String
  tur      String? // lise/ortaokul için okul türü; üniversitede boş
  katilim  Int
}