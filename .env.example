# Yerelde (geliştirme) SQLite dosyası kullanır — kurulum gerekmez:
DATABASE_URL="file:./dev.db"

# Prodüksiyonda Postgres bağlantı string'i (Neon, Supabase, Railway vb.):
# DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani"

# Oturum çerezlerini imzalamak için rastgele, uzun bir metin.
# Terminalde üretmek için: openssl rand -base64 32
SESSION_SECRET="degistir-bu-cok-onemli"
